<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane style="-fx-background-color: #FFFFFF; -fx-font-family: '-apple-system', 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SignUpController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-padding: 20 50 0 50;">
            <children>
                <HBox spacing="1.0">
                    <Label text="e" textFill="#e53238"><font><Font name="System Bold" size="42.0"/></font></Label>
                    <Label text="b" textFill="#0064d2"><font><Font name="System Bold" size="42.0"/></font></Label>
                    <Label text="i" textFill="#f5af02"><font><Font name="System Bold" size="42.0"/></font></Label>
                    <Label text="d" textFill="#86b817"><font><Font name="System Bold" size="42.0"/></font></Label>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Đã có tài khoản?" textFill="#191919">
                        <font><Font size="16.0"/></font>
                    </Label>
                    <Button mnemonicParsing="false" onAction="#handleBackToLogin" style="-fx-background-color: transparent; -fx-padding: 0; -fx-text-fill: #0654ba; -fx-underline: true; -fx-cursor: hand;" text="Đăng nhập">
                        <font><Font size="16.0"/></font>
                    </Button>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 20;">
            <children>

                <HBox alignment="CENTER" maxWidth="1200.0" maxHeight="700.0" spacing="80.0">
                    <children>

                        <StackPane prefWidth="600.0" prefHeight="700.0" style="-fx-background-color: #F8F8F8; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #E0E0E0; -fx-border-width: 1;">
                            <children>

                                <Label text="Chưa tìm thấy ảnh Mixi Food" textFill="#AAAAAA">
                                    <font><Font name="System Bold" size="18.0"/></font>
                                </Label>

                                <ImageView fx:id="imgMixiBag" fitWidth="580.0" fitHeight="680.0" preserveRatio="true">
                                    <image>
                                        <Image url="@../unnamed.jpg" />
                                    </image>
                                </ImageView>

                            </children>
                        </StackPane>

                        <VBox alignment="CENTER_LEFT" prefWidth="450.0" spacing="25.0">
                            <children>

                                <Label text="Tạo tài khoản" style="-fx-font-weight: 900;">
                                    <font><Font name="System Bold" size="46.0"/></font>
                                </Label>

                                <Region prefHeight="10.0" />

                                <VBox spacing="20.0">
                                    <TextField fx:id="txtUsername" prefHeight="55.0" promptText="Tên đăng nhập" style="-fx-background-color: transparent; -fx-border-color: #8f8f8f; -fx-border-radius: 8; -fx-padding: 10 15; -fx-font-size: 16px;" />
                                    <PasswordField fx:id="txtPassword" prefHeight="55.0" promptText="Mật khẩu" style="-fx-background-color: transparent; -fx-border-color: #8f8f8f; -fx-border-radius: 8; -fx-padding: 10 15; -fx-font-size: 16px;" />
                                    <ComboBox fx:id="cbRole" prefHeight="55.0" maxWidth="Infinity" promptText="Chọn vai trò tham gia" style="-fx-background-color: transparent; -fx-border-color: #8f8f8f; -fx-border-radius: 8; -fx-font-size: 16px;">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="BIDDER" />
                                                <String fx:value="SELLER" />
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </VBox>

                                <Label text="Bằng việc chọn Tạo tài khoản, bạn đồng ý với Thỏa thuận Người dùng của chúng tôi và xác nhận đã đọc Thông báo Quyền riêng tư." textFill="#707070" wrapText="true" prefWidth="450.0">
                                    <font><Font size="13.0"/></font>
                                </Label>

                                <Label fx:id="lblMessage" textFill="#e53238" wrapText="true" />

                                <Button onAction="#handleRegister" prefHeight="55.0" maxWidth="Infinity" style="-fx-background-color: #3665f3; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" text="Tạo tài khoản" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </StackPane>
    </center>
</BorderPane>